# Obrigatório para gerar análise completa com IA.
# Sem essas variáveis, o endpoint funciona em modo básico com manchetes organizadas.
OPENAI_API_KEY=coloque_sua_chave_aqui
OPENAI_MODEL=coloque_um_modelo_liberado_no_seu_projeto

# Usado apenas para forçar atualização com ?force=1
CRON_SECRET=gere_uma_senha_forte_com_16_ou_mais_caracteres

# Opcional no teste local
PORT=3000
